{
    "name": "noc-foundry Dev Environment",
    // Update the container version when you publish dev-container
    // "image": "noc-foundry-dev:latest",
    // Replace with uncommented line below to build your own local copy of the image
    "dockerFile": "../docker/Dockerfile-dev",
    "containerEnv": {
        // Uncomment to overwrite devcontainer .kube/config and .minikube certs with the localhost versions
        // each time the devcontainer starts, if the respective .kube-localhost/config and .minikube-localhost
        // folders respectively are bind mounted to the devcontainer.
        // "SYNC_LOCALHOST_KUBECONFIG": "true",
        // Enable docker-from-docker by symlinking /var/run/docker.sock to /var/run/docker-host.sock
        // "BIND_LOCALHOST_DOCKER": "true",
        // Path inside container for workspace (used by docker-compose for volume mounts)
        "WORKSPACE_FOLDER": "${localWorkspaceFolder}"
    },
    "features": {
        "ghcr.io/devcontainers/features/sshd:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "initializeCommand": "docker network create noc-foundry-devnet || true",
    "postCreateCommand": "chmod +x ./.devcontainer/scripts/docker-post-create.sh && ./.devcontainer/scripts/docker-post-create.sh",
    "mounts": [
        // Mount docker-in-docker storage from local folder for persistence across devcontainer rebuilds
        // "type=bind,source=${localWorkspaceFolder}/.devcontainer/.docker-storage,target=/var/lib/docker",
        // Uncomment below to mount docker-in-docker library volume if you prefer using a volume for docker storage
        // "type=volume,source=dind-var-lib-docker,target=/var/lib/docker",
        // Bind mount docker socket under an alias to support docker-from-docker
        "type=bind,source=/var/run/docker.sock,target=/var/run/docker-host.sock"
        // Uncomment to clone local .kube/config into devcontainer
        // "type=bind,source=${env:HOME}${env:USERPROFILE}/.kube,target=/home/noc-foundry/.kube-localhost",
        // Uncomment to additionally clone minikube certs into devcontainer for use with .kube/config
        // "type=bind,source=${env:HOME}${env:USERPROFILE}/.minikube,target=/home/noc-foundry/.minikube-localhost"
    ],
    // Always run image-defined default command
    "overrideCommand": false,
    // On Linux, this will prevent new files getting created as root, but you
    // may need to update the USER_UID and USER_GID in docker/Dockerfile-dev
    // to match your user if not 1000.
    "remoteUser": "noc-foundry",
    "runArgs": [
        // Enable ptrace-based debugging for go
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined",
        // Uncomment to bind to host network for local devcontainer; this is necessary if using the
        // bind-mounted /var/run/docker-host.sock directly.
        // "--net=host",
        "--net=noc-foundry-devnet",
        // Enable docker-in-docker configuration. Comment out if not using for better security.
        "--privileged",
        // Run the entrypoint defined in container image.
        "--init"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "davidanson.vscode-markdownlint",
                "golang.go",
                "shardulm94.trailing-spaces",
                "Gruntfuggly.todo-tree",
                "bierner.emojisense",
                "stkb.rewrap",
                "vscode-icons-team.vscode-icons",
                "github.vscode-pull-request-github",
                "redhat.vscode-yaml",
                "bajdzis.vscode-database",
                "IBM.output-colorizer",
                "github.copilot",
                "ms-vscode.makefile-tools",
                "GitHub.copilot-chat",
                "golang.Go",
                "openai.chatgpt"
            ],
            "settings": {
                "files.eol": "\n",
                "editor.formatOnSave": true,
                "go.toolsManagement.checkForUpdates": "local",
                "go.useLanguageServer": true,
                "go.gopath": "/go",
                "go.buildTags": "",
                "git.alwaysSignOff": true,
                "go.lintOnSave": "package",
                "[go]": {
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "always"
                    }
                },
                "[html]": {
                    "editor.formatOnSave": false
                },
                "files.associations": {
                    "*.html": "html"
                },
                "terminal.integrated.env.linux": {
                    "GOLANG_PROTOBUF_REGISTRATION_CONFLICT": "ignore"
                }
            }
        }
    },
    "workspaceFolder": "/workspaces/noc-foundry",
    "workspaceMount": "type=bind,source=${localWorkspaceFolder},target=/workspaces/noc-foundry"
}